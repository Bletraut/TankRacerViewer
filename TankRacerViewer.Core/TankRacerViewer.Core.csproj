<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
  </PropertyGroup>
  <PropertyGroup>
	<Version>1.0.0</Version>
	<Company>Bletraut</Company>
	<Product>Tank Racer Viewer</Product>
	<Copyright>Copyright (C) 2026 Aleksandr Pachaev</Copyright>
	<RepositoryUrl>https://github.com/Bletraut/TankRacerViewer</RepositoryUrl>
	<Description>Reverse-engineering tool for inspecting and extracting assets from Tank Racer file formats.</Description>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="Content\bin\**" />
    <Compile Remove="Content\obj\**" />
    <EmbeddedResource Remove="Content\bin\**" />
